ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-genai-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# --- McpDeck: connect REAL MCP servers (optional) ---
# Leave unset → McpDeck uses the built-in mock servers (fs/git/linear).
# Set to a JSON array of stdio server configs → McpDeck connects for real and
# the header badge flips from "mock" to "live mcp". Verified against the
# official filesystem server. Example (one server; use absolute paths):
# MCPDECK_SERVERS=[{"id":"fs","name":"Filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","D:/path/to/expose"]}]

# --- Kit apps: where the 18 apps' actions write their real files ---
# Each app's approved action writes a real artifact (.ics, .csv, .md, .svg, …)
# through a real MCP filesystem server, sandboxed to this directory.
# Unset → <project>/app-output. Set to an absolute path to redirect it.
# APPS_MCP_DIR=D:/path/to/app-output

# --- Tillpoint: REAL Stripe charge (TEST MODE ONLY) ---
# Unset → Tillpoint writes a receipt file only (simulated payment).
# Set to a Stripe TEST secret key → checkout creates a real test PaymentIntent
# (test card pm_card_visa) and records the real id/status on the receipt.
# A live key (sk_live_…) is REFUSED by the code. Test mode moves no real money.
# STRIPE_SECRET_KEY=sk_test_your_key_here
