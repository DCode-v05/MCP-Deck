# --- LLM keys (McpDeck agent + craft authoring) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-genai-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# --- McpDeck: connect REAL MCP servers (optional) ---
# Leave unset → McpDeck uses the built-in mock servers (git/linear) and the
# header badge reads "mock". Set to a JSON array of stdio server configs → McpDeck
# connects for real and the badge flips to "live mcp". Each SaaS server only
# starts when its credential (below) is present; an unconfigured one is skipped.
# (Exact package names can vary — use whichever MCP server you have installed.)
# MCPDECK_SERVERS=[
#   {"id":"github","name":"GitHub","command":"npx","args":["-y","@modelcontextprotocol/server-github"]},
#   {"id":"notion","name":"Notion","command":"npx","args":["-y","@notionhq/notion-mcp-server"]},
#   {"id":"linear","name":"Linear","command":"npx","args":["-y","@tacticlaunch/mcp-linear"]},
#   {"id":"slack","name":"Slack","command":"npx","args":["-y","@modelcontextprotocol/server-slack"]}
# ]

# Per-server credentials — kept on their own lines and passed through to the
# servers (so a token never has to live inside the MCPDECK_SERVERS JSON blob):
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
# NOTION_TOKEN=ntn_...                 # share a page/database with the integration
# LINEAR_API_TOKEN=lin_api_...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T...
# SLACK_CHANNEL_IDS=C...,C...
